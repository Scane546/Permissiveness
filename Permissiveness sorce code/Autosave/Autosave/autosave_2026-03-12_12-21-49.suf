<Events>
<Event>
<Name>On Preload</Name>
<Args/>
<Script>-- Эти действия будут выполнены перед отображением диалога.

-- Получение кода ошибки при выполнении последней операции.
error = Application.GetLastError();

-- Если был получен код ошибки, то отобразим её на экране.
if (error ~= 0) then
    Dialog.Message("Error", _tblErrorMessages[error], MB_OK, MB_ICONEXCLAMATION);
end

</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Back</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Назад".

-- переход на предыдущий диалог
Screen.Back();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Next</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Готово".

-- если отмечен 1-й чекбокс, то будет выполнен запуск установленного приложения
if check01 then
	File.Run(SessionVar.Expand("%AppFolder%").."\\Permissiveness.exe", "", "", SW_SHOWNORMAL, false);
end

-- если отмечен 2-й чекбокс, то будет выполнен переход на указанную адрес в Интернете.
if check02 then
	File.Open("https://github.com/Scane546/Permissiveness/", "", SW_SHOWNORMAL);
end


-- завершение работы инсталлятора
Application.Exit();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Отмена".

-- Функция из общего сценария _SUF70_Global_Functions.lua:
-- спрашиваем подтверждения пользователя на выход из приложения
if g_ConfirmSetupAbort() then
	Application.Exit(EXIT_REASON_USER_ABORTED);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Help</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Справка".
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Ctrl Message</Name>
<Args>number e_CtrlID, number e_MsgID, table e_Details</Args>
<Script>-- Эти действия будут выполнены при взаимодействии пользователя
-- с элементами управления на текущем диалоге.

if (e_MsgID == MSGID_CLICKED) then
	-- по элементу управления был сделан клик...

	if (e_CtrlID == CTRL_BUTTON_01) then

		-- Введите здесь ваш код обработки события.
		
		Dialog.Message("Click","You clicked on Button 01", MB_OK, MB_ICONNONE);
	end
	
	if (e_CtrlID == CTRL_BUTTON_02) then

		-- Введите здесь ваш код обработки события.
		
		Dialog.Message("Click","You clicked on Button 02", MB_OK, MB_ICONNONE);
	end

end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
</Events>
