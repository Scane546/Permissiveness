<Variable>%AppFolder%</Variable>
<Events>
<Event>
<Name>On Preload</Name>
<Args/>
<Script>-- Эти действия будут выполнены перед отображением диалога.

-- Вычисление размера свободного места необходимого для установки продукта.
_SpaceRequired = SetupData.CalculateRequiredSpace();

-- Преобразование формата данных к соответствующим единицам измерения (например "0 байт").
local strSpaceRequired = String.GetFormattedSize(_SpaceRequired);

-- Сохранение результата в переменной, чтобы использовать его в строковом элементе диалога.
SessionVar.Set("%SpaceRequired%", strSpaceRequired);

-- Функция из общего сценария _SUF70_Global_Functions.lua:
-- обновление данных поля для строки "Требуется на диске:".
g_UpdateStaticTextCtrl(CTRL_STATICTEXT_SPACEREQUIRED, "IDS_CTRL_STATICTEXT_SPACEREQUIRED");
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Back</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Назад".

-- переход на предыдущий диалог
Screen.Back();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Next</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Далее".

-- Функция из общего сценария _SUF70_Global_Functions.lua:
-- проверка правильности пути для папки установки (имеет соответствующий формат строки).
if(g_IsValidPath(strInstallFolderPath)) then

	-- Если на выбранном диске достаточно свободного места, то выполняется переход к следующему диалогу.
	if(_SpaceAvailable &gt;= _SpaceRequired) then
		-- Свободного места на диске достаточно... поэтому
		-- переход на следующий диалог
		Screen.Next();
	else
		-- на диске недостаточно свободного места...
		
		-- Функция из общего сценария _SUF70_Global_Functions.lua:
		-- спрашиваем пользователя о дальнейших действиях
		if g_ConfirmFreeSpaceOverride() then
			-- Пользователь решил продолжить установку... поэтому
			-- переход на следующий диалог
			Screen.Next();
		end
	end
else
	-- Путь к папке является недействительным...
	
	local strTitle = SetupData.GetLocalizedString("MSG_INVALID_ENTRY");
	local strPrompt;

	-- Функция из общего сценария _SUF70_Global_Functions.lua:
	-- проверка формата строки, которая содержит путь к устанавливаемой папке.
	if(g_ContainsValidPathChars(strInstallFolderPath)) then
		-- Строка имеет неверный формат.
		strPrompt = SetupData.GetLocalizedString("ERR_INVALID_PATH");
	else
		-- В строке содержатся недопустимые символы.
		strPrompt = SetupData.GetLocalizedString("ERR_INVALID_CHARACTERS") .. "\r\n/ * ? \" &lt; &gt; |";		
	end

	-- Сообщаем пользователю о том, чтобы он хорошенько подумал :)
	Dialog.Message(strTitle, strPrompt, MB_OK, MB_ICONEXCLAMATION);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Отмена".

-- Функция из общего сценария _SUF70_Global_Functions.lua:
-- спрашиваем подтверждения пользователя на выход из приложения
if g_ConfirmSetupAbort() then
	Application.Exit(EXIT_REASON_USER_ABORTED);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Help</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Справка".
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Ctrl Message</Name>
<Args>number e_CtrlID, number e_MsgID, table e_Details</Args>
<Script>-- Эти действия будут выполнены при взаимодействии пользователя
-- с элементами управления на текущем диалоге.

if(e_CtrlID == CTRL_BUTTON_BROWSE) then
	-- Обработка события при нажатии кнопки "Обзор...".

	-- Если кнопка была нажата, то открываем диалог с выбором папки установки
	-- и обновляем папку установки.
	if (e_MsgID == MSGID_CLICKED) then

		-- Получение текстовой метки для поля с папкой установки
		-- (эта строка будет использована для заголовка окна с выбором папки установки).
		local strPrompt = Screen.GetLocalizedString("IDS_CTRL_STATICTEXT_LABEL_01");
		strPrompt = SessionVar.Expand(strPrompt);
		
		-- Функция из общего сценария _SUF70_Global_Functions.lua:
		-- отображение диалога для изменения пути установки продукта.
		g_EditFieldFolderBrowse(CTRL_EDIT_FOLDER, strPrompt);
	end
end


if(e_CtrlID == CTRL_EDIT_FOLDER) then
	-- Обработка события для элемента управления с папкой установки...

	-- Если в элементе произошли изменения, например, изменился путь установки,
	-- то вычисляется размер доступного места на выбранном диске.
	if (e_MsgID == MSGID_ONCHANGED) then

		strInstallFolderPath = e_Details.Text;
		
		-- Функция из общего сценария _SUF70_Global_Functions.lua:
		-- вычисление свободного места, доступного на выбранном диске.
		_SpaceAvailable = g_GetFreeSpaceInBytes(strInstallFolderPath);

		-- Преобразование значения %SpaceAvailable% к соответствующим единицам измерениям (например, "0 байт").
		SessionVar.Set("%SpaceAvailable%", String.GetFormattedSize(_SpaceAvailable) );

		-- Функция из общего сценария _SUF70_Global_Functions.lua:
		-- обновление данных поля для строки "Свободно на диске:".
		g_UpdateStaticTextCtrl(CTRL_STATICTEXT_SPACEAVAILABLE, "IDS_CTRL_STATICTEXT_SPACEAVAILABLE");
	end
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
</Events>
