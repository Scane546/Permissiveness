<Events>
<Event>
<Name>On Preload</Name>
<Args/>
<Script>-- Эти действия будут выполнены перед отображением диалога.
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Back</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Назад".

-- переход на предыдущий диалог
Screen.Back();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Next</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Далее".
-- Подсказка: На этом этапе вы можете ввести проверочные действия,
-- которые будут выполнены прежде, чем пользователь увидит следующий диалог.

-- Создание ярлыков согласно отмеченным пунктам.
-- Этот блок сценария необходимо скопировать в сценарии "On Post Install" раздела "Действия".
-- А здесь удалить или установить атрибут комментария.
-- Если вы будете использовать этот диалог для создания ярлыков, то не забудьте снять
-- отметки с соответствующих пунктов создания ярлыков в свойствах проекта.
-- // ------------------------------------------------------------------------------------ \\ --
if (desktop_icon) then
    local iconfolder = Shell.GetFolder(SHF_DESKTOP);
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (startup_icon) then
    local iconfolder = Shell.GetFolder(SHF_STARTUP);
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (quicklaunch_icon) then
    local iconfolder = SessionVar.Expand("%ApplicationDataFolder%") ..
        "\\Microsoft\\Internet Explorer\\Quick Launch";
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (startmenu_icon) then
    local iconfolder = Shell.GetFolder(SHF_STARTMENU);
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (programs_icon) then
    local iconfolder = Shell.GetFolder(SHF_STARTMENUPROGRAMS);
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (appfolder_icon) then
    local iconfolder = Shell.GetFolder(SHF_STARTMENUPROGRAMS);
    Shell.CreateShortcut(iconfolder .. SessionVar.Expand("\\%AppShortcutFolderName%"),
        SessionVar.Expand("%ProductName%"), SessionVar.Expand("%AppFolder%\\Permissiveness.exe"),
        "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
-- \\ ------------------------------------------------------------------------------------ // --

-- переход на следующий диалог
Screen.Next();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Отмена".

-- Функция из общего сценария _SUF70_Global_Functions.lua:
-- спрашиваем подтверждения пользователя на выход из приложения
if g_ConfirmSetupAbort() then
	Application.Exit(EXIT_REASON_USER_ABORTED);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
