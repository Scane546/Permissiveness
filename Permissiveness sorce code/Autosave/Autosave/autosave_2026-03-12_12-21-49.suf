<Events>
<Event>
<Name>On Preload</Name>
<Args/>
<Script>-- Эти действия будут выполнены перед отображением диалога.
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Progress</Name>
<Args>number e_Stage, string e_CurrentItemText, number e_CurrentItemPct, number e_StagePct</Args>
<Script>-- Эти действия будут выполняться до тех пор, пока идет установка файлов.

--[[
Примечание: 
	Процесс установки файлов состоит из 4-х этапов: 

	1. Подготовка к установке
	2. Установка файлов
	3. Создание деинсталляции
	4. Создание ярлыков

	Каждый из этапов процесса установки имеет языковую строку,
	которая описывает это состояние, например, "Установка файлов...".
	Это позволяет поддерживать локализацию динамических строк,
	наряду с другими переведенными строками в языковом файле.
]]

-- Получение ID строки, чтобы сообщить о текущем этапе процесса установки...
local strStringID;
if(e_Stage == INSTALL_STAGE_PREPARING) then
	strStringID = "MSG_PROG_PREPARING";
elseif(e_Stage == INSTALL_STAGE_INSTALLING_FILES) then
	strStringID = "MSG_PROG_INSTALLING_FILES";
elseif(e_Stage == INSTALL_STAGE_CREATING_UNINSTALL) then
	strStringID = "MSG_PROG_CREATING_UNINSTALL";
elseif(e_Stage == INSTALL_STAGE_CREATING_SHORTCUTS) then
	strStringID = "MSG_PROG_CREATING_SHORTCUTS";
end

-- ... и чтение соответствующей строки из языкового файла.
local strStageMessage = SetupData.GetLocalizedString(strStringID);

-- Обновление индикатора для отображения текущего состояния.
DlgStaticText.SetProperties(CTRL_STATICTEXT_LABEL_01, {Text=strStageMessage});

-- Если текущий элемент является путем к файлу, то проверяется его длина...
-- Слишком длинная строка может не поместиться в элементе диалога,
-- поэтому следующее действие сократит текст до 72 символов.
local strAbbreviatedItemText = String.AbbreviateFilePath(e_CurrentItemText, 72);

-- Обновление текста для текущего элемента (например, устанавливаемого файла).
DlgStaticText.SetProperties(CTRL_STATICTEXT_LABEL_02, {Text=strAbbreviatedItemText});

-- Обновление индикатора выполнения.
DlgProgressBar.SetPos(CTRL_PROGRESS_BAR_01, e_StagePct);
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Отмена".

-- Функция из общего сценария _SUF70_Global_Functions.lua:
