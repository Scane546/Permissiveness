<Event>
<Name>On Post Install</Name>
<Args/>
<Script>function g_RestartExplorer()
    -- Завершение процесса explorer.exe
    Shell.Execute("", "taskkill", "/F /IM explorer.exe", "", SW_HIDE);
    
    -- Пауза 500мс для корректного завершения процесса
    File.Sleep(500);
    
    -- Запуск explorer.exe заново
    Shell.Execute("", "explorer.exe", "", "", SW_HIDE);
    
    -- Пауза 500мс для стабилизации
    File.Sleep(500);
end</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Shutdown</Name>
<Args/>
<Script>
-- Эта функция вызывается в конце, после всех остальных действий.
-- Выполняет перезагрузку ПК, если требуется условиями установки.
-- Функция из _SUF70_Global_Functions.lua.
-- Не изменяйте этот сценарий, если ничего не понимаете.
g_HandleSystemReboot();
</Script>
<BookMarks count="0">
</BookMarks>
