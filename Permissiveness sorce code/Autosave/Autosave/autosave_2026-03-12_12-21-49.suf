</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Next</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Далее".
-- Подсказка: На этом этапе вы можете ввести проверочные действия,
-- которые будут выполнены прежде, чем пользователь увидит следующий диалог.

-- переход на следующий диалог
Screen.Next();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Отмена".

-- Функция из общего сценария _SUF70_Global_Functions.lua:
-- спрашиваем подтверждения пользователя на выход из приложения
if g_ConfirmSetupAbort() then
	Application.Exit(EXIT_REASON_USER_ABORTED);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Help</Name>
<Args/>
<Script>-- Эти действия будут выполнены при нажатии на кнопку "Справка".
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Ctrl Message</Name>
<Args>number e_CtrlID, number e_MsgID, table e_Details</Args>
<Script>-- Эти действия будут выполнены при взаимодействии пользователя
-- с элементами управления на текущем диалоге.

if (e_CtrlID == CTRL_RADIOBTN_AGREE or e_CtrlID == CTRL_RADIOBTN_DISAGREE) then
	-- Проверяется событие при выборе одного из элементов управления "RadioButton".
	-- В зависимости от сделанного выбора, изменяется состояние кнопки "Далее".
	if (e_MsgID == MSGID_CLICKED) then
		-- Функция из общего сценария _SUF70_Global_Functions.lua:
		-- если с лицензией согласны, то кнопка "Далее" становится активной.
		g_LicenseAgreementScreen_UpdateNextButton();
	end
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
</Events>
