<Events>
<Event>
<Name>On Preload</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïåðåä îòîáðàæåíèåì äèàëîãà.

-- Âû÷èñëåíèå ðàçìåðà ñâîáîäíîãî ìåñòà íåîáõîäèìîãî äëÿ óñòàíîâêè ïðîäóêòà.
_SpaceRequired = SetupData.CalculateRequiredSpace();

-- Ïðåîáðàçîâàíèå ôîðìàòà äàííûõ ê ñîîòâåòñòâóþùèì åäèíèöàì èçìåðåíèÿ (íàïðèìåð "0 áàéò").
local strSpaceRequired = String.GetFormattedSize(_SpaceRequired);

-- Ñîõðàíåíèå ðåçóëüòàòà â ïåðåìåííîé, ÷òîáû èñïîëüçîâàòü åãî â ñòðîêîâîì ýëåìåíòå äèàëîãà.
SessionVar.Set("%SpaceRequired%", strSpaceRequired);

-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
-- îáíîâëåíèå äàííûõ ïîëÿ äëÿ ñòðîêè "Òðåáóåòñÿ íà äèñêå:".
g_UpdateStaticTextCtrl(CTRL_STATICTEXT_SPACEREQUIRED, "IDS_CTRL_STATICTEXT_SPACEREQUIRED");
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Back</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Íàçàä".

-- ïåðåõîä íà ïðåäûäóùèé äèàëîã
Screen.Back();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Next</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Äàëåå".

-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
-- ïðîâåðêà ïðàâèëüíîñòè ïóòè äëÿ ïàïêè óñòàíîâêè (èìååò ñîîòâåòñòâóþùèé ôîðìàò ñòðîêè).
if(g_IsValidPath(strInstallFolderPath)) then

	-- Åñëè íà âûáðàííîì äèñêå äîñòàòî÷íî ñâîáîäíîãî ìåñòà, òî âûïîëíÿåòñÿ ïåðåõîä ê ñëåäóþùåìó äèàëîãó.
	if(_SpaceAvailable &gt;= _SpaceRequired) then
		-- Ñâîáîäíîãî ìåñòà íà äèñêå äîñòàòî÷íî... ïîýòîìó
		-- ïåðåõîä íà ñëåäóþùèé äèàëîã
		Screen.Next();
	else
		-- íà äèñêå íåäîñòàòî÷íî ñâîáîäíîãî ìåñòà...
		
		-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
		-- ñïðàøèâàåì ïîëüçîâàòåëÿ î äàëüíåéøèõ äåéñòâèÿõ
		if g_ConfirmFreeSpaceOverride() then
			-- Ïîëüçîâàòåëü ðåøèë ïðîäîëæèòü óñòàíîâêó... ïîýòîìó
			-- ïåðåõîä íà ñëåäóþùèé äèàëîã
			Screen.Next();
		end
	end
else
	-- Ïóòü ê ïàïêå ÿâëÿåòñÿ íåäåéñòâèòåëüíûì...
	
	local strTitle = SetupData.GetLocalizedString("MSG_INVALID_ENTRY");
	local strPrompt;

	-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
	-- ïðîâåðêà ôîðìàòà ñòðîêè, êîòîðàÿ ñîäåðæèò ïóòü ê óñòàíàâëèâàåìîé ïàïêå.
	if(g_ContainsValidPathChars(strInstallFolderPath)) then
		-- Ñòðîêà èìååò íåâåðíûé ôîðìàò.
		strPrompt = SetupData.GetLocalizedString("ERR_INVALID_PATH");
	else
		-- Â ñòðîêå ñîäåðæàòñÿ íåäîïóñòèìûå ñèìâîëû.
		strPrompt = SetupData.GetLocalizedString("ERR_INVALID_CHARACTERS") .. "\r\n/ * ? \" &lt; &gt; |";		
	end

	-- Ñîîáùàåì ïîëüçîâàòåëþ î òîì, ÷òîáû îí õîðîøåíüêî ïîäóìàë :)
	Dialog.Message(strTitle, strPrompt, MB_OK, MB_ICONEXCLAMATION);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Îòìåíà".

-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
-- ñïðàøèâàåì ïîäòâåðæäåíèÿ ïîëüçîâàòåëÿ íà âûõîä èç ïðèëîæåíèÿ
if g_ConfirmSetupAbort() then
	Application.Exit(EXIT_REASON_USER_ABORTED);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Help</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Ñïðàâêà".
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Ctrl Message</Name>
<Args>number e_CtrlID, number e_MsgID, table e_Details</Args>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè âçàèìîäåéñòâèè ïîëüçîâàòåëÿ
-- ñ ýëåìåíòàìè óïðàâëåíèÿ íà òåêóùåì äèàëîãå.

if(e_CtrlID == CTRL_BUTTON_BROWSE) then
	-- Îáðàáîòêà ñîáûòèÿ ïðè íàæàòèè êíîïêè "Îáçîð...".

	-- Åñëè êíîïêà áûëà íàæàòà, òî îòêðûâàåì äèàëîã ñ âûáîðîì ïàïêè óñòàíîâêè
	-- è îáíîâëÿåì ïàïêó óñòàíîâêè.
	if (e_MsgID == MSGID_CLICKED) then

		-- Ïîëó÷åíèå òåêñòîâîé ìåòêè äëÿ ïîëÿ ñ ïàïêîé óñòàíîâêè
		-- (ýòà ñòðîêà áóäåò èñïîëüçîâàíà äëÿ çàãîëîâêà îêíà ñ âûáîðîì ïàïêè óñòàíîâêè).
		local strPrompt = Screen.GetLocalizedString("IDS_CTRL_STATICTEXT_LABEL_01");
		strPrompt = SessionVar.Expand(strPrompt);
		
		-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
		-- îòîáðàæåíèå äèàëîãà äëÿ èçìåíåíèÿ ïóòè óñòàíîâêè ïðîäóêòà.
		g_EditFieldFolderBrowse(CTRL_EDIT_FOLDER, strPrompt);
	end
end


if(e_CtrlID == CTRL_EDIT_FOLDER) then
	-- Îáðàáîòêà ñîáûòèÿ äëÿ ýëåìåíòà óïðàâëåíèÿ ñ ïàïêîé óñòàíîâêè...

	-- Åñëè â ýëåìåíòå ïðîèçîøëè èçìåíåíèÿ, íàïðèìåð, èçìåíèëñÿ ïóòü óñòàíîâêè,
	-- òî âû÷èñëÿåòñÿ ðàçìåð äîñòóïíîãî ìåñòà íà âûáðàííîì äèñêå.
	if (e_MsgID == MSGID_ONCHANGED) then

		strInstallFolderPath = e_Details.Text;
		
		-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
		-- âû÷èñëåíèå ñâîáîäíîãî ìåñòà, äîñòóïíîãî íà âûáðàííîì äèñêå.
		_SpaceAvailable = g_GetFreeSpaceInBytes(strInstallFolderPath);

		-- Ïðåîáðàçîâàíèå çíà÷åíèÿ %SpaceAvailable% ê ñîîòâåòñòâóþùèì åäèíèöàì èçìåðåíèÿì (íàïðèìåð, "0 áàéò").
		SessionVar.Set("%SpaceAvailable%", String.GetFormattedSize(_SpaceAvailable) );

		-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
		-- îáíîâëåíèå äàííûõ ïîëÿ äëÿ ñòðîêè "Ñâîáîäíî íà äèñêå:".
		g_UpdateStaticTextCtrl(CTRL_STATICTEXT_SPACEAVAILABLE, "IDS_CTRL_STATICTEXT_SPACEAVAILABLE");
	end
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
</Events>
