<Events>
<Event>
<Name>On Preload</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïåðåä îòîáðàæåíèåì äèàëîãà.

-- Ïîëó÷åíèå êîäà îøèáêè ïðè âûïîëíåíèè ïîñëåäíåé îïåðàöèè.
error = Application.GetLastError();

-- Åñëè áûë ïîëó÷åí êîä îøèáêè, òî îòîáðàçèì å¸ íà ýêðàíå.
if (error ~= 0) then
    Dialog.Message("Error", _tblErrorMessages[error], MB_OK, MB_ICONEXCLAMATION);
end

</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Back</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Íàçàä".

-- ïåðåõîä íà ïðåäûäóùèé äèàëîã
Screen.Back();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Next</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Ãîòîâî".

-- åñëè îòìå÷åí 1-é ÷åêáîêñ, òî áóäåò âûïîëíåí çàïóñê óñòàíîâëåííîãî ïðèëîæåíèÿ
if check01 then
	File.Run(SessionVar.Expand("%AppFolder%").."\\Permissiveness.exe", "", "", SW_SHOWNORMAL, false);
end

-- åñëè îòìå÷åí 2-é ÷åêáîêñ, òî áóäåò âûïîëíåí ïåðåõîä íà óêàçàííóþ àäðåñ â Èíòåðíåòå.
if check02 then
	File.Open("https://github.com/Scane546/Permissiveness/", "", SW_SHOWNORMAL);
end


-- çàâåðøåíèå ðàáîòû èíñòàëëÿòîðà
Application.Exit();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Îòìåíà".

-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
-- ñïðàøèâàåì ïîäòâåðæäåíèÿ ïîëüçîâàòåëÿ íà âûõîä èç ïðèëîæåíèÿ
if g_ConfirmSetupAbort() then
	Application.Exit(EXIT_REASON_USER_ABORTED);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Help</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Ñïðàâêà".
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Ctrl Message</Name>
<Args>number e_CtrlID, number e_MsgID, table e_Details</Args>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè âçàèìîäåéñòâèè ïîëüçîâàòåëÿ
-- ñ ýëåìåíòàìè óïðàâëåíèÿ íà òåêóùåì äèàëîãå.

if (e_MsgID == MSGID_CLICKED) then
	-- ïî ýëåìåíòó óïðàâëåíèÿ áûë ñäåëàí êëèê...

	if (e_CtrlID == CTRL_BUTTON_01) then

		-- Ââåäèòå çäåñü âàø êîä îáðàáîòêè ñîáûòèÿ.
		
		Dialog.Message("Click","You clicked on Button 01", MB_OK, MB_ICONNONE);
	end
	
	if (e_CtrlID == CTRL_BUTTON_02) then

		-- Ââåäèòå çäåñü âàø êîä îáðàáîòêè ñîáûòèÿ.
		
		Dialog.Message("Click","You clicked on Button 02", MB_OK, MB_ICONNONE);
	end

end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
</Events>
