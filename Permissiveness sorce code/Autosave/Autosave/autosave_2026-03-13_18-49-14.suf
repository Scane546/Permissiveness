<Events>
<Event>
<Name>On Preload</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïåðåä îòîáðàæåíèåì äèàëîãà.
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Back</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Íàçàä".

-- ïåðåõîä íà ïðåäûäóùèé äèàëîã
Screen.Back();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Next</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Äàëåå".
-- Ïîäñêàçêà: Íà ýòîì ýòàïå âû ìîæåòå ââåñòè ïðîâåðî÷íûå äåéñòâèÿ,
-- êîòîðûå áóäóò âûïîëíåíû ïðåæäå, ÷åì ïîëüçîâàòåëü óâèäèò ñëåäóþùèé äèàëîã.

-- Ñîçäàíèå ÿðëûêîâ ñîãëàñíî îòìå÷åííûì ïóíêòàì.
-- Ýòîò áëîê ñöåíàðèÿ íåîáõîäèìî ñêîïèðîâàòü â ñöåíàðèè "On Post Install" ðàçäåëà "Äåéñòâèÿ".
-- À çäåñü óäàëèòü èëè óñòàíîâèòü àòðèáóò êîììåíòàðèÿ.
-- Åñëè âû áóäåòå èñïîëüçîâàòü ýòîò äèàëîã äëÿ ñîçäàíèÿ ÿðëûêîâ, òî íå çàáóäüòå ñíÿòü
-- îòìåòêè ñ ñîîòâåòñòâóþùèõ ïóíêòîâ ñîçäàíèÿ ÿðëûêîâ â ñâîéñòâàõ ïðîåêòà.
-- // ------------------------------------------------------------------------------------ \\ --
if (desktop_icon) then
    local iconfolder = Shell.GetFolder(SHF_DESKTOP);
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (startup_icon) then
    local iconfolder = Shell.GetFolder(SHF_STARTUP);
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (quicklaunch_icon) then
    local iconfolder = SessionVar.Expand("%ApplicationDataFolder%") ..
        "\\Microsoft\\Internet Explorer\\Quick Launch";
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (startmenu_icon) then
    local iconfolder = Shell.GetFolder(SHF_STARTMENU);
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (programs_icon) then
    local iconfolder = Shell.GetFolder(SHF_STARTMENUPROGRAMS);
    Shell.CreateShortcut(iconfolder, SessionVar.Expand("%ProductName%"),
        SessionVar.Expand("%AppFolder%\\Permissiveness.exe"), "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
 
if (appfolder_icon) then
    local iconfolder = Shell.GetFolder(SHF_STARTMENUPROGRAMS);
    Shell.CreateShortcut(iconfolder .. SessionVar.Expand("\\%AppShortcutFolderName%"),
        SessionVar.Expand("%ProductName%"), SessionVar.Expand("%AppFolder%\\Permissiveness.exe"),
        "", "", "", 0, SW_SHOWNORMAL, nil, "");
end
-- \\ ------------------------------------------------------------------------------------ // --

-- ïåðåõîä íà ñëåäóþùèé äèàëîã
Screen.Next();
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Îòìåíà".

-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
-- ñïðàøèâàåì ïîäòâåðæäåíèÿ ïîëüçîâàòåëÿ íà âûõîä èç ïðèëîæåíèÿ
if g_ConfirmSetupAbort() then
	Application.Exit(EXIT_REASON_USER_ABORTED);
end
</Script>
<BookMarks count="0">
</BookMarks>
