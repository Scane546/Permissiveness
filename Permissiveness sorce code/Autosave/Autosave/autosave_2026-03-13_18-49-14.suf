<Name>On Post Install</Name>
<Args/>
<Script>function g_RestartExplorer()
    -- Çàâåðøåíèå ïðîöåññà explorer.exe
    Shell.Execute("", "taskkill", "/F /IM explorer.exe", "", SW_HIDE);
    
    -- Ïàóçà 500ìñ äëÿ êîððåêòíîãî çàâåðøåíèÿ ïðîöåññà
    File.Sleep(500);
    
    -- Çàïóñê explorer.exe çàíîâî
    Shell.Execute("", "explorer.exe", "", "", SW_HIDE);
    
    -- Ïàóçà 500ìñ äëÿ ñòàáèëèçàöèè
    File.Sleep(500);
end</Script>
<BookMarks count="0">
</BookMarks>
</Event>
