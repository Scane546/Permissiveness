<Events>
<Event>
<Name>On Preload</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïåðåä îòîáðàæåíèåì äèàëîãà.
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Progress</Name>
<Args>number e_Stage, string e_CurrentItemText, number e_CurrentItemPct, number e_StagePct</Args>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíÿòüñÿ äî òåõ ïîð, ïîêà èäåò óñòàíîâêà ôàéëîâ.

--[[
Ïðèìå÷àíèå: 
	Ïðîöåññ óñòàíîâêè ôàéëîâ ñîñòîèò èç 4-õ ýòàïîâ: 

	1. Ïîäãîòîâêà ê óñòàíîâêå
	2. Óñòàíîâêà ôàéëîâ
	3. Ñîçäàíèå äåèíñòàëëÿöèè
	4. Ñîçäàíèå ÿðëûêîâ

	Êàæäûé èç ýòàïîâ ïðîöåññà óñòàíîâêè èìååò ÿçûêîâóþ ñòðîêó,
	êîòîðàÿ îïèñûâàåò ýòî ñîñòîÿíèå, íàïðèìåð, "Óñòàíîâêà ôàéëîâ...".
	Ýòî ïîçâîëÿåò ïîääåðæèâàòü ëîêàëèçàöèþ äèíàìè÷åñêèõ ñòðîê,
	íàðÿäó ñ äðóãèìè ïåðåâåäåííûìè ñòðîêàìè â ÿçûêîâîì ôàéëå.
]]

-- Ïîëó÷åíèå ID ñòðîêè, ÷òîáû ñîîáùèòü î òåêóùåì ýòàïå ïðîöåññà óñòàíîâêè...
local strStringID;
if(e_Stage == INSTALL_STAGE_PREPARING) then
	strStringID = "MSG_PROG_PREPARING";
elseif(e_Stage == INSTALL_STAGE_INSTALLING_FILES) then
	strStringID = "MSG_PROG_INSTALLING_FILES";
elseif(e_Stage == INSTALL_STAGE_CREATING_UNINSTALL) then
	strStringID = "MSG_PROG_CREATING_UNINSTALL";
elseif(e_Stage == INSTALL_STAGE_CREATING_SHORTCUTS) then
	strStringID = "MSG_PROG_CREATING_SHORTCUTS";
end

-- ... è ÷òåíèå ñîîòâåòñòâóþùåé ñòðîêè èç ÿçûêîâîãî ôàéëà.
local strStageMessage = SetupData.GetLocalizedString(strStringID);

-- Îáíîâëåíèå èíäèêàòîðà äëÿ îòîáðàæåíèÿ òåêóùåãî ñîñòîÿíèÿ.
DlgStaticText.SetProperties(CTRL_STATICTEXT_LABEL_01, {Text=strStageMessage});

-- Åñëè òåêóùèé ýëåìåíò ÿâëÿåòñÿ ïóòåì ê ôàéëó, òî ïðîâåðÿåòñÿ åãî äëèíà...
-- Ñëèøêîì äëèííàÿ ñòðîêà ìîæåò íå ïîìåñòèòüñÿ â ýëåìåíòå äèàëîãà,
-- ïîýòîìó ñëåäóþùåå äåéñòâèå ñîêðàòèò òåêñò äî 72 ñèìâîëîâ.
local strAbbreviatedItemText = String.AbbreviateFilePath(e_CurrentItemText, 72);

-- Îáíîâëåíèå òåêñòà äëÿ òåêóùåãî ýëåìåíòà (íàïðèìåð, óñòàíàâëèâàåìîãî ôàéëà).
DlgStaticText.SetProperties(CTRL_STATICTEXT_LABEL_02, {Text=strAbbreviatedItemText});

-- Îáíîâëåíèå èíäèêàòîðà âûïîëíåíèÿ.
DlgProgressBar.SetPos(CTRL_PROGRESS_BAR_01, e_StagePct);
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
<Event>
<Name>On Cancel</Name>
<Args/>
<Script>-- Ýòè äåéñòâèÿ áóäóò âûïîëíåíû ïðè íàæàòèè íà êíîïêó "Îòìåíà".

-- Ôóíêöèÿ èç îáùåãî ñöåíàðèÿ _SUF70_Global_Functions.lua:
-- ñïðàøèâàåì ïîäòâåðæäåíèÿ ïîëüçîâàòåëÿ íà âûõîä èç ïðèëîæåíèÿ
if g_ConfirmSetupAbort() then
	Application.Exit(EXIT_REASON_USER_ABORTED);
end
</Script>
<BookMarks count="0">
</BookMarks>
</Event>
